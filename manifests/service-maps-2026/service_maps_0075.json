      "annotations": [
        {
          "id": "https://tamulib-dc-labs.github.io/custom-iiif-manifests/manifests/service-maps-2026/service_maps_0075/canvas/1/notderef/annotation/1",
          "type": "AnnotationPage",
          "items": [
            {
              "id": "https://tamulib-dc-labs.github.io/custom-iiif-manifests/manifests/service-maps-2026/service_maps_0075/canvas/1/notdef/annotation/1/annopage-0/annotation-0",
              "type": "Annotation",
              "motivation": "commenting",
              "body": {
                "type": "TextualBody",
                "language": "en",
                "format": "text/plain",
                "value": "<span>HEADQUARTERS 100<sup>TH</sup> INFANTRY DIVISION</span><br/><span>Office of the Commanding General</span><br/><span>APO #447, U. S. Army</span><br/><br/><span>8 August 1945.</span><br/><br/><span>Dear Joe --</span><br/><br/><span>This series of five maps is intended to give a general picture of the operations of the 100th Infantry Division in the European Theater of Operations. It is hoped that they will prove to be of interest to the members of the Division, and that they may form the basis for further and more detailed study by the various organizations of the Division. These maps constitute only a graphical representation of the general operations of the Division. It is expected that a comprehensive narrative will also be available in the not-too-distant future.</span><br/><br/><span>W. A. Burress</span><br/><span>Major General, U. S. Army</span><br/><span>Commanding.</span><br/><br/><span>P. S. Please file these for my return. They really possess great personal & historic value. Sidney</span><br/><br/><span>P. P. S. -- Today I was made a Corporal -- another historic landmark!</span><br/>"
              },
              "target": "https://tamulib-dc-labs.github.io/custom-iiif-manifests/manifests/service-maps-2026/service_maps_0075/canvas/1"
            }
          ]
        }
      ]
    },
